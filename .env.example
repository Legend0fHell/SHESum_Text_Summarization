# Embeddings
# sentence_transformers loads a local/HuggingFace model by name.
# openai_compatible calls /v1/embeddings, e.g. Infinity, vLLM, Ollama-compatible servers.
GRAPHSUM_EMBEDDING_BACKEND=sentence_transformers
GRAPHSUM_EMBEDDING_MODEL=BAAI/bge-m3
GRAPHSUM_EMBEDDING_BASE_URL=http://localhost:7997/v1
GRAPHSUM_EMBEDDING_API_KEY=ollama

# Summarization LLM
GRAPHSUM_LLM_MODEL=Qwen3.6-35B
GRAPHSUM_LLM_BASE_URL=http://localhost:8000/v1
GRAPHSUM_LLM_API_KEY=ollama
GRAPHSUM_LLM_TEMPERATURE=0.0
