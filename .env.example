# Embeddings
# sentence_transformers loads a local/HuggingFace model by name.
# openai_compatible calls /v1/embeddings, e.g. Infinity, vLLM, Ollama-compatible servers.
GRAPHSUM_EMBEDDING_BACKEND=sentence_transformers
GRAPHSUM_EMBEDDING_MODEL=BAAI/bge-m3
GRAPHSUM_EMBEDDING_BASE_URL=http://localhost:7997/v1
GRAPHSUM_EMBEDDING_API_KEY=ollama

# Summarization LLM
GRAPHSUM_LLM_BACKEND=dry_run
GRAPHSUM_LLM_MODEL=Qwen3.6-35B
GRAPHSUM_LLM_BASE_URL=http://localhost:8000/v1
GRAPHSUM_LLM_API_KEY=ollama
GRAPHSUM_LLM_TEMPERATURE=0.0

# Experiment defaults. CLI flags override these values.
# Dataset choices: vn_mds, vims, multi_news. Leave empty to require --dataset.
GRAPHSUM_DATASET=
GRAPHSUM_DATA_ROOT=datasets
GRAPHSUM_LIMIT=3
GRAPHSUM_OUTPUT=runs/graphsum_results.csv
# Leave empty to auto-write <output_stem>_summary.csv only for openai_compatible runs.
GRAPHSUM_AGGREGATE_OUTPUT=

# Pipeline variant choices.
GRAPHSUM_SALIENCE=e2b
GRAPHSUM_CHUNKING=semantic
GRAPHSUM_TARGET_MIN_TOKENS=1000
GRAPHSUM_TARGET_MAX_TOKENS=1500
GRAPHSUM_SEMANTIC_BREAKPOINT_PERCENTILE=65.0
# Leave empty to use max(100, target_min_tokens // 4).
GRAPHSUM_SEMANTIC_MIN_CHUNK_TOKENS=
GRAPHSUM_DRY_EMBED=false
GRAPHSUM_NO_GRAPH=false
GRAPHSUM_PURE_LLM=false
# Leave empty to use dataset defaults: VN-MDS 180 words/300 tokens, ViMs 235 words/380 tokens.
GRAPHSUM_MAX_SUMMARY_WORDS=
GRAPHSUM_MAX_OUTPUT_TOKENS=

# Duplicate-aware graph and community prompt compaction.
GRAPHSUM_DEDUP_CHUNKS=true
GRAPHSUM_DEDUP_SIM_THRESHOLD=0.88
GRAPHSUM_DEDUP_REQUIRE_SHARED_PHRASE=false
GRAPHSUM_DUPLICATE_EDGE_FACTOR=0.35
GRAPHSUM_COMMUNITY_DEDUP=true

# Graph weights. gamma is computed as 1 - alpha - beta.
GRAPHSUM_GRID=false
GRAPHSUM_ALPHA=0.10
GRAPHSUM_BETA=0.20

# PACSUM and entity consolidation.
GRAPHSUM_PACSUM_BETA=0.0
GRAPHSUM_PACSUM_LAMBDA1=0.0
GRAPHSUM_PACSUM_LAMBDA2=1.0
GRAPHSUM_ENTITY_MERGE_THRESHOLD=0.85
